# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# PII Encryption (32 bytes, 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# Tenant provisioning (Levi only)
MASTER_SETUP_KEY=your-secret-setup-key

# Rate limiting (Upstash Redis — optional for local dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy (kept for reference, now per-tenant via webhook_secret column)
VIDEOASK_WEBHOOK_SECRET=your-webhook-secret
